        <xs:element name="BankInternalID" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="LongBankName" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="BankName" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="BankNumber" type="xs:string" minOccurs="0" maxOccurs="1"/>
