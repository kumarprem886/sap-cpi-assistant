              <xs:element name="LastChangeDate"                     type="xs:string" minOccurs="0"/>
              <xs:element name="LastChangedByUser"                  type="xs:string" minOccurs="0"/>
              <xs:element name="LoadingDate"                        type="xs:string" minOccurs="0"/>
