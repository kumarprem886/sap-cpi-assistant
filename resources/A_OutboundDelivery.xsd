              <xs:element name="DeliveryPriority"                   type="xs:string" minOccurs="0"/>
              <xs:element name="DeliveryTime"                       type="xs:string" minOccurs="0"/>
              <xs:element name="DocumentDate"                       type="xs:string" minOccurs="0"/>
              <xs:element name="ExternalIdentifyingNumber"          type="xs:string" minOccurs="0"/>
              <xs:element name="ExternalTransportSystem"            type="xs:string" minOccurs="0"/>
              <xs:element name="FactoryCalendarByCustomer"          type="xs:string" minOccurs="0"/>
              <xs:element name="GoodsIssueOrReceiptSlipNumber"      type="xs:string" minOccurs="0"/>
