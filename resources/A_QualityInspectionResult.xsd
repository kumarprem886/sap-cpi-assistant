<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
  <xs:element name="A_QualityInspectionResult">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="InspectionLot" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotOrigin" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotType" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotStatus" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="Material" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="Plant" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="Batch" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="SampleSize" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
        <xs:element name="SampleSizeUnit" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspLotCreationDate" type="xs:dateTime" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspLotActualQuantity" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
