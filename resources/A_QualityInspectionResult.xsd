        <xs:element name="UsageDecisionCode" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotIsDeleted" type="xs:boolean" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspLotHasDefectData" type="xs:boolean" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotQuantity" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
        <xs:element name="InspectionLotUnit" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="PurchaseOrder" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="Supplier" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="LastChangeDateTime" type="xs:dateTime" minOccurs="0" maxOccurs="1"/>
        <xs:element name="to_InspectionLotCharacteristic" minOccurs="0" maxOccurs="1">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="results" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="InspectionLot" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="InspectionLotCharacteristic" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="CharacteristicShortText" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="InspectionLotSample" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="InspectionValuationResult" type="xs:string" minOccurs="0" maxOccurs="1"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
