        <xs:element name="Language" type="xs:string" minOccurs="0" maxOccurs="1"/>
        <xs:element name="to_CostCenterText" minOccurs="0" maxOccurs="1">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="results" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="CostCenter" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="ControllingArea" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="Language" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="CostCenterName" type="xs:string" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="CostCenterDescription" type="xs:string" minOccurs="0" maxOccurs="1"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
