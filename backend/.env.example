# ── AI Provider ───────────────────────────────────────────────────────────────
# Uncomment ONE provider block. Auto-detected by key presence if AI_PROVIDER is not set.
# Default (no key set): Ollama local — free but requires Ollama installed locally.

# ── Option 1: Ollama — FREE, local, no API key needed ─────────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_VISION_MODEL=llava:7b
# Setup: https://ollama.ai → ollama pull qwen2.5-coder:14b → ollama serve

# ── Option 2: Anthropic Claude — best quality ─────────────────────────────────
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-5
# ANTHROPIC_VISION_MODEL=claude-opus-4-5
# Key: https://console.anthropic.com/

# ── Option 3: Groq — free cloud tier, fast ────────────────────────────────────
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# Key: https://console.groq.com/ (free)

# ── Option 4: OpenAI GPT ──────────────────────────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# Key: https://platform.openai.com/

# ── Option 5: Google Gemini — has free tier ───────────────────────────────────
# AI_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash
# Key: https://aistudio.google.com/

# ── Option 6: OpenRouter — many models, some free ────────────────────────────
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# Key: https://openrouter.ai/

# ── Option 7: Mistral AI ──────────────────────────────────────────────────────
# AI_PROVIDER=mistral
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-large-latest
# Key: https://console.mistral.ai/

# ── Option 8: NVIDIA NIM ──────────────────────────────────────────────────────
# AI_PROVIDER=nvidia
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Key: https://build.nvidia.com/

# ── SAP CPI Tenant Connection (for CPI Connect page) ─────────────────────────
# Leave blank if you don't have a CPI tenant — all other features still work.
CPI_AUTH_TYPE=oauth
CPI_API_BASE_URL=https://<tenant>.it-cpi018.cfapps.<region>.hana.ondemand.com/api/v1
CPI_BASE_URL=https://<tenant>.it-cpi018-rt.cfapps.<region>.hana.ondemand.com
CPI_CLIENT_ID=sb-xxxxxxxx...
CPI_CLIENT_SECRET=xxxxxxxx...
CPI_TOKEN_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com/oauth/token

# Basic auth alternative:
# CPI_AUTH_TYPE=basic
# CPI_USER=S0012345
# CPI_PASS=yourpassword

# ── App Security ──────────────────────────────────────────────────────────────
# Change this to a random string in production
JWT_SECRET=change-this-to-a-random-secret-string
