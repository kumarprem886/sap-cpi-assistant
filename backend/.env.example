# ── AI Provider — pick ONE block ──────────────────────────────────────────────

# Option A: Ollama — FREE, runs locally, no key needed (recommended for privacy)
#   1. Install: https://ollama.ai
#   2. Pull model: ollama pull qwen2.5-coder:14b
#   3. (Optional vision): ollama pull llava:7b
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_VISION_MODEL=llava:7b

# Option B: Anthropic Claude — best quality, needs API key
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-5

# Option C: Groq — free cloud tier, weaker quality, 12K token limit
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── CPI Connection ────────────────────────────────────────────────────────────
CPI_AUTH_TYPE=oauth
CPI_API_BASE_URL=https://<tenant>.it-cpi018.cfapps.eu10.hana.ondemand.com/api/v1
CPI_CLIENT_ID=sb-...
CPI_CLIENT_SECRET=...
CPI_TOKEN_URL=https://<subaccount>.authentication.eu10.hana.ondemand.com/oauth/token
